<Window x:Class="GPULCD.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GPULCD Monitor"
        Width="400" Height="700"
        MinWidth="360" MinHeight="500"
        Background="{StaticResource BgPrimary}"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing"
        StateChanged="Window_StateChanged">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="GPULCD Monitor"
                       FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimary}"/>
            <TextBlock Text="Turing Smart Screen Controller"
                       FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
        </StackPanel>

        <!-- Status -->
        <Border Grid.Row="1" Background="{StaticResource BgSecondary}"
                CornerRadius="8" Padding="12" Margin="0,0,0,12">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="LCD:" Foreground="{StaticResource TextSecondary}"
                               FontWeight="SemiBold" Width="60"/>
                    <TextBlock Grid.Column="1" Text="{Binding ConnectionStatus}"
                               Foreground="{StaticResource TextPrimary}"/>
                </Grid>
                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Sensors:" Foreground="{StaticResource TextSecondary}"
                               FontWeight="SemiBold" Width="60"/>
                    <TextBlock Grid.Column="1" Text="{Binding SensorStatus}"
                               Foreground="{StaticResource TextPrimary}"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- LCD Preview -->
        <Border Grid.Row="2" Background="{StaticResource BgSecondary}"
                CornerRadius="8" Padding="8" Margin="0,0,0,12">
            <Grid>
                <Image Source="{Binding PreviewImage}"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                <TextBlock Text="LCD Preview" Opacity="0.3"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{StaticResource TextMuted}" FontSize="14"
                           Visibility="{Binding PreviewImage, Converter={x:Null}, TargetNullValue=Visible, FallbackValue=Collapsed}"/>
            </Grid>
        </Border>

        <!-- Page Switcher -->
        <Border Grid.Row="3" Background="{StaticResource BgSecondary}"
                CornerRadius="8" Padding="8" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="&#9664;" Command="{Binding PrevPageCommand}"
                        Background="Transparent" Foreground="{StaticResource TextSecondary}"
                        BorderThickness="0" FontSize="16" Cursor="Hand"/>
                <TextBlock Grid.Column="1" Text="{Binding CurrentPageName}"
                           Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold"
                           HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13"/>
                <Button Grid.Column="2" Content="&#9654;" Command="{Binding NextPageCommand}"
                        Background="Transparent" Foreground="{StaticResource TextSecondary}"
                        BorderThickness="0" FontSize="16" Cursor="Hand"/>
            </Grid>
        </Border>

        <!-- Brightness -->
        <Border Grid.Row="4" Background="{StaticResource BgSecondary}"
                CornerRadius="8" Padding="12" Margin="0,0,0,12">
            <StackPanel>
                <Grid>
                    <TextBlock Text="Brightness" Foreground="{StaticResource TextSecondary}" FontWeight="SemiBold"/>
                    <TextBlock HorizontalAlignment="Right" Foreground="{StaticResource TextPrimary}">
                        <Run Text="{Binding Brightness, Mode=OneWay}"/><Run Text="%"/>
                    </TextBlock>
                </Grid>
                <Slider Minimum="0" Maximum="100" Value="{Binding Brightness}"
                        Margin="0,6,0,0" IsSnapToTickEnabled="True" TickFrequency="5"/>
            </StackPanel>
        </Border>

        <!-- Start/Stop -->
        <Button Grid.Row="5" Height="40"
                Command="{Binding StartStopCommand}"
                Background="{StaticResource BgTertiary}"
                Foreground="{StaticResource TextPrimary}"
                FontSize="14" FontWeight="SemiBold"
                BorderThickness="0"
                Cursor="Hand">
            <Button.Style>
                <Style TargetType="Button">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                            <Setter Property="Content" Value="Stop"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsRunning}" Value="False">
                            <Setter Property="Content" Value="Start"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>
    </Grid>
</Window>
